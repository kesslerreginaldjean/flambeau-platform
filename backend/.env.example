# =========================
# Backend Configuration
# =========================
# IMPORTANT: copy this file to .env and replace every placeholder.
# Generate strong secrets with: openssl rand -hex 48

# Server
NODE_ENV=development
PORT=5000

# Database — Prisma datasource
# Default: local SQLite. Switch to Postgres in production:
#   DATABASE_URL=postgresql://user:password@host:5432/flambeau
DATABASE_URL="file:./prisma/dev.db"

# JWT — REQUIRED in production (server refuses to start without it)
JWT_SECRET=
JWT_EXPIRES_IN=2h
BCRYPT_COST=12

# CORS — comma-separated origins allowed by the API (only one is supported here)
FRONTEND_URL=http://localhost:3000

# Payments (Kotelam) — leave PAYMENTS_ENABLED=false until credentials + webhook secret are issued
PAYMENTS_ENABLED=false
KOTELAM_API_KEY=
KOTELAM_API_URL=
KOTELAM_MERCHANT_ID=
KOTELAM_WEBHOOK_SECRET=

# AI chatbot (Gemini) — disabled by default
AI_ENABLED=false
GEMINI_API_KEY=
