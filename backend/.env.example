# Backend Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/flambeau_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=flambeau_user
DB_PASSWORD=secure_password_here
DB_NAME=flambeau_db

# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=24h

# Kotelam Configuration
KOTELAM_API_KEY=your_kotelam_api_key
KOTELAM_API_URL=https://api.kotelam.ht
KOTELAM_MERCHANT_ID=your_merchant_id

# Accounting
ACCOUNTING_MODULE_ENABLED=true
CURRENCY=HTG

# Frontend URL
FRONTEND_URL=http://localhost:3000
